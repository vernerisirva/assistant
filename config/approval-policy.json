{
  "initialTrustMode": "confirm-before-action",
  "approvalChannel": "telegram",
  "allowedWithoutExtraApproval": [
    "read-telegram-messages-sent-to-assistant",
    "summarize-configured-gmail-and-calendar",
    "read-configured-todoist-tasks",
    "search-min-golf-tee-time-availability",
    "draft-min-golf-booking-approval-request",
    "read-local-memory",
    "remember-explicit-low-risk-memory",
    "forget-single-memory-by-request",
    "create-explicit-complete-calendar-event",
    "create-explicit-complete-todoist-task",
    "rename-explicit-todoist-task",
    "update-explicit-todoist-task-description",
    "append-explicit-todoist-task-comment",
    "reschedule-explicit-todoist-task",
    "label-explicit-todoist-task",
    "draft-email-calendar-plan-grocery-and-health-recommendations",
    "draft-todoist-task-changes",
    "ask-clarifying-questions",
    "send-check-ins",
    "run-read-only-project-diagnostics"
  ],
  "lowRiskAdditiveActions": {
    "requireExplicitUserInstruction": true,
    "requireCompleteCriticalFields": true,
    "requireAdditiveOnly": true,
    "requireNoExternalRecipients": true,
    "requireEasyUndo": true,
    "approvalStillRequiredWhen": [
      "critical-fields-inferred-from-image-or-ocr",
      "date-year-time-timezone-or-calendar-is-uncertain",
      "target-is-ambiguous",
      "edits-deletes-moves-completes-or-sends",
      "invites-messages-books-pays-purchases-or-submits-forms",
      "sensitive-memory-or-private-health-finance-data-is-involved"
    ]
  },
  "lowRiskTodoistTaskChanges": {
    "requireExactTaskTarget": true,
    "requireExplicitUserInstruction": true,
    "requireCompleteCriticalFields": true,
    "allowedWhenExactAndExplicit": [
      "rename-task",
      "append-description-or-comment",
      "replace-description",
      "change-due-date",
      "add-or-remove-labels"
    ],
    "approvalStillRequiredWhen": [
      "delete-complete-reopen-or-move-task",
      "bulk-edits",
      "ambiguous-task-target",
      "details-inferred-from-image-or-ocr",
      "replace-description-without-explicit-replace-instruction",
      "affects-other-people"
    ]
  },
  "approvalRequired": [
    {
      "domain": "email",
      "actions": ["send", "delete", "archive", "label", "mark-read", "move"]
    },
    {
      "domain": "calendar",
      "actions": ["create-event", "edit-event", "delete-event", "respond-to-invite"]
    },
    {
      "domain": "shell",
      "actions": ["write-files", "change-settings", "launch-apps", "install-software", "run-state-changing-commands"]
    },
    {
      "domain": "browser",
      "actions": ["submit-forms", "purchase", "book", "post", "message", "change-account-state"]
    },
    {
      "domain": "todoist",
      "actions": ["create-task", "edit-task", "complete-task", "reopen-task", "delete-task", "reschedule-task", "move-task", "comment"]
    },
    {
      "domain": "min-golf",
      "actions": ["book-tee-time", "edit-booking", "cancel-tee-time", "add-player", "remove-player", "pay-greenfee", "book-cart", "check-in"]
    },
    {
      "domain": "memory",
      "actions": ["remember-sensitive-preference", "export-memory", "bulk-delete-memory"]
    },
    {
      "domain": "files",
      "actions": ["edit-outside-requested-implementation", "delete", "move-sensitive-files"]
    },
    {
      "domain": "sensitive-local-data",
      "actions": ["read-private-directories", "extract-secrets", "inspect-unrelated-personal-data"]
    },
    {
      "domain": "purchases-and-finance",
      "actions": ["pay", "trade", "transfer", "subscribe", "order-delivery"]
    }
  ],
  "approvalPromptRequiredFields": [
    "agent",
    "action",
    "target",
    "expectedEffect",
    "risk",
    "approvalOptions"
  ],
  "approvalLanguage": {
    "mode": "flexible-explicit",
    "requiresPendingApprovalPrompt": true,
    "acceptedExamples": ["approve", "ok", "okay", "that's ok", "yes do it", "go ahead", "proceed", "sounds good", "looks good", "sure"],
    "rejectedExamples": ["no", "do not approve", "stop", "cancel", "is that ok?", "maybe ok"]
  },
  "auditLogFields": [
    "timestamp",
    "agent",
    "action",
    "target",
    "expectedEffect",
    "risk",
    "approvalOptions",
    "decision",
    "result"
  ],
  "trustLadder": [
    {
      "mode": "confirm-before-action",
      "description": "All side effects require explicit approval."
    },
    {
      "mode": "trusted-routine",
      "description": "A named low-risk routine can run automatically after repeated successful approvals."
    },
    {
      "mode": "permanent-approval-required",
      "description": "High-risk actions stay approval-gated even when routine actions become trusted."
    }
  ]
}
