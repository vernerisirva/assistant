{
  "name": "assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local OpenClaw multi-agent assistant accessed through Telegram.",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "validate:env": "node scripts/validate-env.mjs",
    "render:config": "node scripts/render-openclaw-config.mjs",
    "doctor": "node scripts/doctor.mjs",
    "todoist": "node scripts/todoist.mjs",
    "mingolf": "node scripts/mingolf.mjs",
    "memory": "node scripts/memory.mjs",
    "routine": "node scripts/routine.mjs",
    "routines:plan": "node scripts/routines-cron.mjs plan",
    "routines:install": "node scripts/routines-cron.mjs install",
    "routines:status": "node scripts/routines-cron.mjs status",
    "routines:enable": "node scripts/routines-cron.mjs enable",
    "routines:disable": "node scripts/routines-cron.mjs disable",
    "routines:set-time": "node scripts/routines-cron.mjs set-time",
    "routines:skips": "node scripts/routines-cron.mjs skips",
    "routines:skip": "node scripts/routines-cron.mjs skip",
    "routines:unskip": "node scripts/routines-cron.mjs unskip",
    "start:openclaw": "node scripts/start-openclaw.mjs",
